{
  "hosting": {
    "target": "arboryx-ai",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "*.config",
      "*.config.example",
      "deploy.sh"
    ],
    "rewrites": [
      {
        "source": "/__session/**",
        "run": { "serviceId": "arboryx-auth", "region": "us-central1" }
      },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "**/*.@(png|ico|svg)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      }
    ]
  }
}
